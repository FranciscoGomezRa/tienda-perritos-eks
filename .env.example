# ====== Plantilla de variables de entorno (Tienda Perritos) ======
# Copia este archivo a ".env" y rellena los valores reales.
# El ".env" está en .gitignore: NO se sube al repositorio.
# Estos mismos valores se cargan luego como GitHub Secrets (Environment 'production').

# --- Base de datos MySQL ---
DB_USER=root
MYSQL_ROOT_PASSWORD=cambia_esta_password
DB_NAME=tienda_perritos
DB_PORT=3306

# --- AWS / EKS (estos NO van en .env; van directo a GitHub Secrets) ---
# Se listan aquí solo como referencia de los nombres que debes crear:
# AWS_ACCESS_KEY_ID=...        (del AWS Details del Learner Lab; ROTA cada sesión)
# AWS_SECRET_ACCESS_KEY=...    (del AWS Details del Learner Lab; ROTA cada sesión)
# AWS_SESSION_TOKEN=...        (del AWS Details del Learner Lab; ROTA cada sesión)
# AWS_REGION=us-east-1
# EKS_CLUSTER_NAME=tienda-eks
# EKS_NAMESPACE=tienda
